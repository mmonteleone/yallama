  pull)        cmd_pull "$@" ;;
  list|ls)     cmd_list "$@" ;;
  remove|rm)   cmd_remove "$@" ;;
  run)         cmd_run "$@" ;;
  serve)       cmd_serve "$@" ;;
  ps)          cmd_ps "$@" ;;
  profile)     cmd_profile "$@" ;;
  versions)    cmd_versions "$@" ;;
  prune)       cmd_prune "$@" ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    cmd_help >&2
    exit 1
    ;;
esac
